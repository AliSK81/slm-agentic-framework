# --- SLM (all providers defined in configs/models.yaml) ---
# Switch provider: set SLM_PROVIDER to a key under providers: (openrouter, deepseek, ollama, ...)
SLM_PROVIDER=deepseek

# Provider credentials (names must match api_key_env / base_url_env in models.yaml)
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=

# Role → profile keys in configs/models.yaml (not API model ids)
PLANNER_PROFILE=default
EXECUTOR_PROFILE=default

# Memory backend: "redis" or "sqlite"
MEMORY_BACKEND=sqlite

REDIS_URL=redis://localhost:6379
SQLITE_PATH=./data/framework.db

WORKSPACE_ROOT=./workspace
CHECKPOINT_DIR=./checkpoints
TRACE_DIR=./traces

DEFAULT_MAX_STEPS=20
DEFAULT_MAX_RETRIES=3
THINKING_BUDGET=2048
