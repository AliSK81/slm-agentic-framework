# Python
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg

# Environment and secrets
.env

# Data and runtime
data/
workspace/
*.db
*.sqlite3

# Checkpoints and traces (keep dirs via .gitkeep)
checkpoints/*
!checkpoints/.gitkeep
traces/*
!traces/.gitkeep

# IDE and OS
.idea/
.vscode/
.cursor/
.claude/
*.swp
.DS_Store
Thumbs.db

# Generated reports and internal docs
reports/
PROGRESS.md

# E2E / eval run logs (framework logging, staged runners, reruns)
logs/*
!logs/.gitkeep
*.log
*.log.session

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Chroma / model caches
.chroma/

# Local scratch / handoff artifacts (not versioned)
temp/

# Test fixture artifacts (generated by aviona during tests)
tests/fixtures/sample_repo/hello.txt
tests/fixtures/sample_repo/tests/

# Egg-info (editable installs)
src/*.egg-info/
