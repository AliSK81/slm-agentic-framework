traces/*
!traces/.gitkeep

# IDE and OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Generated reports
thesis_evaluation_report.md

# E2E / eval run logs (framework logging, staged runners, reruns)
logs/*
!logs/.gitkeep
*.log
*.log.session

# Testing and coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Chroma / model caches
.chroma/

# Local scratch / handoff artifacts (not versioned)
temp/
