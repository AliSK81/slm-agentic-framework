# --- SLM (all providers defined in configs/models.yaml) ---
# Switch provider: set SLM_PROVIDER to a key under providers: (deepseek, openrouter, mohaymen, ollama, ...)
SLM_PROVIDER=ollama

# DeepSeek API (V4 Flash — default model for planner/executor)
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Mohaymen AI gateway (OpenAI-compatible)
MOHAYMEN_API_KEY=your_key_here
MOHAYMEN_BASE_URL=https://ai-gateway.mohaymen.ir/v1

OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=

# Role → profile keys in configs/models.yaml (not API model ids)
PLANNER_PROFILE=ollama-qwen3-4b-instruct
EXECUTOR_PROFILE=ollama-gpt-oss-20b

# Memory backend: "redis" or "sqlite"
MEMORY_BACKEND=sqlite

REDIS_URL=redis://localhost:6379
SQLITE_PATH=./data/framework.db

WORKSPACE_ROOT=./workspace
CHECKPOINT_DIR=./checkpoints
TRACE_DIR=./traces
# E2E framework logs (pytest -m e2e) → logs/e2e_<timestamp>.log

DEFAULT_MAX_STEPS=20
DEFAULT_MAX_RETRIES=3
THINKING_BUDGET=2048
