*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg

# Environment and secrets
.env

# Data and runtime
data/
workspace/
*.db
*.sqlite3

# Checkpoints and traces (keep dirs via .gitkeep)
checkpoints/*
